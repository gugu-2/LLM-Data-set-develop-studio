# ═══════════════════════════════════════════════════════
#  Hypasia AI — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── LLM Judge (required for best scoring quality) ──────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=                          # Optional fallback
ANTHROPIC_API_KEY=                       # Optional fallback

# ── HuggingFace (required for HF dataset import/export) ─
HUGGINGFACE_TOKEN=your_hf_token_here

# ── Cloud Platforms (Phase 2 — Fine-Tuning Studio) ─────
GOOGLE_CLOUD_PROJECT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# ── Scoring Configuration ───────────────────────────────
# Which judge to use: gemini | heuristic | openai
HYPASIA_JUDGE=gemini

# Default quality threshold (rows below this are rejected)
HYPASIA_THRESHOLD=7.0

# Default language filter (empty = keep all languages)
HYPASIA_LANGUAGE=en

# ── Storage ─────────────────────────────────────────────
HYPASIA_OUTPUT_DIR=./hypasia_output
HYPASIA_MODELS_DIR=./models

# ── Logging ─────────────────────────────────────────────
HYPASIA_LOG_LEVEL=INFO
